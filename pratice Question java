class RailwayReservation {
    int availableTickets = 1;

    synchronized void bookTicket(String name) {
        if (availableTickets > 0) {
            System.out.println(name + ": Ticket booked successfully");
            availableTickets--;
        } else {
            System.out.println(name + ": No tickets available");
        }
    }

    public static void main(String[] args) {
        RailwayReservation system = new RailwayReservation();
        Thread t1 = new Thread(() -> system.bookTicket("User 1"));
        Thread t2 = new Thread(() -> system.bookTicket("User 2"));
        
        t1.start();
        t2.start();
    }
}

class OnlineShoppingSystem {
    public static void main(String[] args) {
        Thread payment = new Thread(() -> System.out.println("Processing payment..."));
        Thread order = new Thread(() -> System.out.println("Order confirmed..."));
        
        payment.start();
        try { payment.join(); } catch (InterruptedException e) {}
        order.start();
    }
}

class ThreadPrioritySystem extends Thread {
    public void run() {
        System.out.println(Thread.currentThread().getName() + " executing messages.");
    }

    public static void main(String[] args) {
        ThreadPrioritySystem t1 = new ThreadPrioritySystem();
        ThreadPrioritySystem t2 = new ThreadPrioritySystem();
        
        t1.setName("Low Priority Thread");
        t2.setName("High Priority Thread");
        
        t1.setPriority(Thread.MIN_PRIORITY);
        t2.setPriority(Thread.MAX_PRIORITY);
        
        t1.start();
        t2.start();
    }
}

class Restaurant {
    boolean foodReady = false;

    synchronized void prepareFood() {
        System.out.println("Chef prepared food");
        foodReady = true;
        notify();
    }

    synchronized void serveFood() {
        while (!foodReady) {
            try { wait(); } catch (InterruptedException e) {}
        }
        System.out.println("Waiter served food");
        foodReady = false;
    }

    public static void main(String[] args) {
        Restaurant r = new Restaurant();
        new Thread(r::serveFood).start();
        new Thread(r::prepareFood).start();
    }
}

class BankingSystem {
    int balance = 1000;

    void withdraw(int amount, String user) {
        synchronized (this) {
            if (balance >= amount) {
                balance -= amount;
                System.out.println(user + " deducted " + amount + ". Remaining balance: " + balance);
            } else {
                System.out.println(user + " attempted deduction. Insufficient funds.");
            }
        }
    }

    public static void main(String[] args) {
        BankingSystem bank = new BankingSystem();
        Thread t1 = new Thread(() -> bank.withdraw(600, "Alice"));
        Thread t2 = new Thread(() -> bank.withdraw(600, "Bob"));
        
        t1.start();
        t2.start();
    }
}

class ChatApplication {
    public static void main(String[] args) {
        Thread sender = new Thread(() -> {
            System.out.println("Sending messages...");
            try { Thread.sleep(500); } catch (Exception e) {}
            System.out.println("Message sent.");
        });

        Thread receiver = new Thread(() -> {
            System.out.println("Waiting to receive messages...");
            try { Thread.sleep(1000); } catch (Exception e) {}
            System.out.println("Receiving messages.");
        });

        System.out.println("Sender State before start: " + sender.getState()); // NEW
        sender.start();
        receiver.start();
        System.out.println("Sender State after start: " + sender.getState()); // RUNNABLE
    }
}