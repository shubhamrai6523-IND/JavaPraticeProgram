class PasswordMaskingSystem {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
        System.out.print("Enter password: ");
        String password = sc.nextLine();
        
        if (password.length() > 2) {
            String toReplace = password.substring(0, password.length() - 2);
            String stars = "";
            for (int i = 0; i < toReplace.length(); i++) {
                stars += "*";
            }
            String masked = password.replace(toReplace, stars);
            System.out.println("Masked password: " + masked);
        } else {
            System.out.println("Masked password: " + password);
        }
    }
}

